alias epoch='date +%s'
alias epochms='date +%s.%N'

alias fn='find . -name'
fa() {
	find / -mount ${ignore_dirs} $@ -print
}

fan() {
	fa -name $@
}

alias pingf='ping -c 1 1.1.1.1'

