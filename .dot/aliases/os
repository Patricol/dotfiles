# vim:filetype=sh

alias logs='sudo journalctl -xe'

alias scu-dr='systemctl --user daemon-reload'
alias scu-rd='scu-dr'
alias sc-dr='sudo systemctl daemon-reload'
alias sc-rd='sc-dr'
alias sc-logs='sudo journalctl --lines=10000 --pager-end --unit'
alias scu-logs='journalctl --user --lines=10000 --pager-end --unit'
alias rr='echo "run-regularly..."; sudo systemctl restart run-regularly.service'

alias syu='pacman -Syu && pacman -S'
alias pacs='syu'
alias pacsd='pacs --asdeps'
alias pacse='pacman -D --asexplicit'
alias pacr='pacman -R'
alias pacrs='pacman -Rs'

pq() {
	declare search="$1"
	if [[ -n "${search}" ]]; then
		pacman -Q | grep "${search}"
	else
		pacman -Q
	fi
}
pqe() {
	declare search="$1"
	if [[ -n "${search}" ]]; then
		pacman -Qe | grep "${search}"
	else
		pacman -Qe
	fi
}
pqd() {
	declare search="$1"
	if [[ -n "${search}" ]]; then
		pacman -Qd | grep "${search}"
	else
		pacman -Qd
	fi
}
pqed() {
	# find explicitly installed packages that depend (directly or indirectly) on the given package
	declare package="$1"
	if [[ -n "${package}" ]]; then
		pacman -Qqe $(pactree --linear --unique --reverse ${package}) | sort
	else
		echo "usage: pqed package"
	fi
}
pqedm() {
	local package
	for package in $@; do
		if pacman -Q "${package}" &> /dev/null; then
			echo "List of explicily installed packages that require ${package}:"
			pqed "${package}"
		fi
	done
}
alias pqi='pacman -Qi'
alias pqunneeded='pacman -Qittd'

pcps() {
	# check package size; also prints the package names
	declare packages="$@"
	pacman -Qi ${packages} | egrep "^(Name|Description|Installed)" | cut -f2 -d":" | paste - - - | awk -F "\t" '{ print $3 "\t" $1 "\t" $2 }' | sort -k 2,2 -k 1n,1n
	# cannot have quotes around ${packages}
}


alias pqenb='comm -23 <(pacman -Qqe | sort) <(pacman -Qqg base base-devel | sort)'
alias listexplicitlyinstalled='pcps "$(pqenb)"'

