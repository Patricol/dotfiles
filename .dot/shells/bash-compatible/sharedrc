# vim:filetype=sh

# Alias definitions.
source ~/.dot/l/source-aliases
if ! [[ -d "${HOME}/.history" ]]; then
	mkdir -p "${HOME}/.history"
fi

if [[ -d "${HOME}/.ssh/auto" ]]; then
	add_ssh_keys $(find "${HOME}/.ssh/auto" ! -type d)
fi

export EDITOR="vim"
export VISUAL="vim"

if which vimpager &> /dev/null; then
	export PAGER="vimpager"
	#alias less=${PAGER}
	#alias zless=${PAGER}
else
	export PAGER="less"
fi

export BROWSER=lynx

export LESSHISTFILE="${HOME}/.history/less"


if [[ -z "${DISPLAY}" ]]; then
	neofetch
fi

export TERM=linux # otherwise things mess up for urxvt (via ssh) etc.

stty -ixon # disable Ctrl-S

ier yay --news # warns me of news I need to know before updating

